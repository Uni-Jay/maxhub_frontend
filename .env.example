# Frontend Environment Configuration

## Development
VITE_APP_API_URL=http://localhost:3000/api
VITE_APP_ENV=development

## Production
# VITE_APP_API_URL=https://api.maxhub.com/api
# VITE_APP_ENV=production

## Features
VITE_APP_ENABLE_2FA=true
VITE_APP_ENABLE_NOTIFICATIONS=true
VITE_APP_ENABLE_AUDIT_LOG=true

## Cloudinary (document & image uploads)
## Create a free account at cloudinary.com, then:
##   1. Copy your Cloud Name from the dashboard
##   2. Create an unsigned Upload Preset in Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

## Theme
VITE_APP_THEME=light
VITE_APP_PRIMARY_COLOR=#000000
VITE_APP_SECONDARY_COLOR=#7c3aed
